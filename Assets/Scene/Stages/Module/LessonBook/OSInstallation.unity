  m_Script: {fileID: 11500000, guid: cd8f8ce2fb929114f841c9e41beb59b6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ModuleContentController
  moduleImage: {fileID: 2137772561}
  descriptionText: {fileID: 1675565176}
  moduleImages:
  - {fileID: 6337327465474107384, guid: ebfcb2114cc91024aa72ced3650d29fb, type: 3}
  - {fileID: -5477092247777095785, guid: 60c33b91cc5f7074ebbeec81c852b8d9, type: 3}
  - {fileID: 3815970425536431362, guid: 5c7077b5701c93b479c38988af3345a2, type: 3}
  - {fileID: 6414242586449817357, guid: 0385305dec13aa04eb52f9c1da2e02ae, type: 3}
  - {fileID: 1601986537069981244, guid: 022801b6b0065834387b3421ba34cfec, type: 3}
  - {fileID: 661398123316141319, guid: 4472f7e9d55ad314aab342c90c25c7ec, type: 3}
  - {fileID: 6069676502573107046, guid: 8ebb4977b75a7864882902c97c1ace4a, type: 3}
  - {fileID: -2520283832257394651, guid: 502885c3e5f6a1e4ba0621a4f918edec, type: 3}
  - {fileID: 2119584205308622581, guid: cac3674402db004438eca30be8345c80, type: 3}
  descriptions:
  - "OS (Operating System) installation means putting the main software that runs
    a computer into it. The OS is what lets you use apps, files, internet, and everything
    else.\r\nExamples of operating systems:\r\nWindows 11\r\nmacOS\r\nUbuntu\r\nThink
    of the OS as the \u201Cboss\u201D of the computer \u2014 it controls all hardware
    and software.\r\n\r\nSimple Analogy\r\nComputer = Body\r\nOS = Brain\r\n Without
    the OS, the computer can\u2019t function properly.\r\n"
  - 'A USB flash drive (at least 8GB)

    OS installer file (like Windows installer)

    A
    computer

'
  - 'Go to the official website and download the installer:

    Example: Windows
    installer from Microsoft

'
  - 'Use tools like:

    Rufus

    Windows Media Creation Tool

    This step turns
    your USB into something the computer can use to install the OS.

'
  - 'Plug in the USB

    Restart the computer

    Enter Boot Menu (usually press
    F2, F12, or DEL)'
  - Choose the USB device so the computer starts from it instead of the hard drive.
  - 'The screen will guide you:

    Choose language

    Select disk (where to install
    OS)

    Click install

'
  - The computer will install the OS and restart automatically.
  - 'After installation:

    Create username

    Set password

    Connect to internet

'
